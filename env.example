# ─────────────────────────────────────────────────────────────────────────────
# Alchemy — on-chain data
# ─────────────────────────────────────────────────────────────────────────────
# Get your key at https://dashboard.alchemy.com
# The user must enable the target network in the Alchemy dashboard first.
#
# Network name follows the pattern: https://{network}.g.alchemy.com/v2/{key}
# Examples:
#   eth-mainnet       Ethereum mainnet
#   base-mainnet      Base
#   arb-mainnet       Arbitrum One
#   opt-mainnet       Optimism
#   polygon-mainnet   Polygon PoS
ALCHEMY_API_KEY=your_key_here
ALCHEMY_NETWORK=eth-mainnet
